{
  "manifest_version": 3,
  "name": "Open Screen Studio",
  "short_name": "Open Studio",
  "version": "0.1.0",
  "description": "Record polished Chrome demos with smooth cursor motion and automatic zooms.",
  "minimum_chrome_version": "118",
  "permissions": [
    "activeTab",
    "debugger",
    "downloads",
    "offscreen",
    "scripting",
    "storage",
    "tabCapture",
    "unlimitedStorage"
  ],
  "host_permissions": ["http://*/*", "https://*/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'; worker-src 'self'"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Start recording this tab",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["assets/content.js"],
      "run_at": "document_start"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "MacCtrl+Shift+R"
      },
      "description": "Start or stop recording the active tab"
    }
  },
  "options_page": "editor.html"
}
